@layout.app({title:'Edit Profile'}) 
 @slot('meta')
   @vite('resources/css/profileEdit.css')
 @endslot
 @slot('main')
   <section class="edit-profile-page">
   <div class="edit-card">
      <h1>Edit Profile</h1>
      <form action="/users?_method=put" method="post">
         {{csrfField()}}
         <label>Full Name</label>
         <input type="text" name="fullName" value="{{user.fullName}}">
         <label>Email</label>
         <input type="email" name="email" value="{{user.email}}">
         <hr>
         <h3>Change Password <span class="optional">(optional)</span></h3>
         <p class="small-note">Leave this empty if you don't want to change your password.</p>
         <label>New Password</label>
         <input type="password" name="password">
         <label>Confirm Password</label>
         <input type="password" name="password_confirmation">
         <button type="submit" class="btn-save">Save Changes</button>
      </form>
   </div>
   </section>
 @endslot
@end